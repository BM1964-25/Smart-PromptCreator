{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart Prompt Creator",
  "version": "0.1.0",
  "identifier": "com.smartpromptcreator.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Smart Prompt Creator",
        "width": 1360,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* https://api.openai.com; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
